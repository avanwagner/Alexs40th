  // ═════════════════════════════════════════════════════
  //  Format: 'YYYY-MM-DDTHH:mm:00' in local time.
  //  Set this to the Thursday of the celebration weekend.
  const EVENT_DATE = new Date('2026-06-11T15:00:00');
  // ═════════════════════════════════════════════════════

  // Update the human-readable dateline on the cover
  (function setDateline() {
    try {
      const d = EVENT_DATE;
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const startDay = d.getDate();
      const endDate = new Date(d);
      endDate.setDate(d.getDate() + 2);
      const month = months[d.getMonth()];
      const endMonth = months[endDate.getMonth()];
      const year = d.getFullYear();
      const dateline = (month === endMonth)
        ? `${month} ${startDay}—${endDate.getDate()} · ${year}`
        : `${month} ${startDay} — ${endMonth} ${endDate.getDate()} · ${year}`;
      const el = document.getElementById('dateline');
      if (el) el.textContent = dateline;
    } catch (e) { /* leave default */ }
  })();

  // Countdown
  (function countdown() {
    const pad = n => String(Math.max(0, n)).padStart(2, '0');
    const dEl = document.getElementById('cd-d');
    const hEl = document.getElementById('cd-h');
    const mEl = document.getElementById('cd-m');
    const sEl = document.getElementById('cd-s');

    function tick() {
      const now = new Date();
      const diff = EVENT_DATE - now;
      if (diff <= 0) {
        dEl.textContent = '00'; hEl.textContent = '00';
        mEl.textContent = '00'; sEl.textContent = '00';
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const mins = Math.floor((diff / (1000 * 60)) % 60);
      const secs = Math.floor((diff / 1000) % 60);
      dEl.textContent = pad(days);
      hEl.textContent = pad(hours);
      mEl.textContent = pad(mins);
      sEl.textContent = pad(secs);
    }
    tick();
    setInterval(tick, 1000);
  })();

  // Day card expand / collapse
  document.querySelectorAll('.day').forEach((day) => {
    const header = day.querySelector('.day-header');
    const body = day.querySelector('.day-body');
    header.addEventListener('click', () => {
      const isOpen = day.classList.toggle('open');
      header.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      if (isOpen) {
        body.style.maxHeight = body.scrollHeight + 'px';
      } else {
        body.style.maxHeight = '0px';
      }
    });
  });

  // Re-measure open day-body on resize
  window.addEventListener('resize', () => {
    document.querySelectorAll('.day.open .day-body').forEach((body) => {
      body.style.maxHeight = body.scrollHeight + 'px';
    });
  });

  // Reveal-on-scroll
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Optional: open Day I by default after a beat
  // setTimeout(() => document.querySelector('#day-1 .day-header')?.click(), 600);
</script>

</body>
