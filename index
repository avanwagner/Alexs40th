<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Morons' Dossier · No. XL</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Italiana&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #EFE9DD;
    --bg-deep: #E8E1D3;
    --surface: #F5F0E5;
    --ink: #1C1814;
    --ink-soft: #3A332B;
    --mute: #7A6E5C;
    --mute-2: #A39885;
    --accent: #8B6F47;
    --accent-deep: #6B5436;
    --hairline: rgba(28, 24, 20, 0.16);
    --hairline-strong: rgba(28, 24, 20, 0.32);
    --serif: 'Cormorant Garamond', 'Times New Roman', serif;
    --serif-display: 'Italiana', 'Cormorant Garamond', serif;
    --sans: 'Jost', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--serif);
    font-weight: 400;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Subtle paper grain */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.4;
    background-image:
      radial-gradient(rgba(28,24,20,0.04) 1px, transparent 1px),
      radial-gradient(rgba(28,24,20,0.025) 1px, transparent 1px);
    background-size: 3px 3px, 7px 7px;
    background-position: 0 0, 1px 2px;
    mix-blend-mode: multiply;
  }

  /* Vignette */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(28,24,20,0.08) 100%);
  }

  main {
    position: relative;
    z-index: 3;
  }

  /* ─────────────  FRAME / TOP BAR  ───────────── */
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 22px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink);
    background: linear-gradient(to bottom, var(--bg) 50%, transparent);
    backdrop-filter: blur(2px);
  }
  .topbar .left { display: flex; gap: 22px; align-items: center; }
  .topbar .dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--accent);
  }
  .topbar .right { color: var(--mute); }

  @media (max-width: 720px) {
    .topbar { padding: 16px 20px; font-size: 9px; letter-spacing: 0.22em; }
    .topbar .right { display: none; }
  }

  /* ─────────────  COVER  ───────────── */
  .cover {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    text-align: center;
    position: relative;
  }

  .cover .corner-tl,
  .cover .corner-tr,
  .cover .corner-bl,
  .cover .corner-br {
    position: absolute;
    width: 48px;
    height: 48px;
    border: 1px solid var(--hairline-strong);
  }
  .cover .corner-tl { top: 80px; left: 60px; border-right: 0; border-bottom: 0; }
  .cover .corner-tr { top: 80px; right: 60px; border-left: 0; border-bottom: 0; }
  .cover .corner-bl { bottom: 60px; left: 60px; border-right: 0; border-top: 0; }
  .cover .corner-br { bottom: 60px; right: 60px; border-left: 0; border-top: 0; }

  @media (max-width: 720px) {
    .cover .corner-tl { top: 56px; left: 20px; }
    .cover .corner-tr { top: 56px; right: 20px; }
    .cover .corner-bl { bottom: 30px; left: 20px; }
    .cover .corner-br { bottom: 30px; right: 20px; }
    .cover .corner-tl, .cover .corner-tr, .cover .corner-bl, .cover .corner-br {
      width: 32px; height: 32px;
    }
  }

  .cover-eyebrow {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--mute);
    margin-bottom: 80px;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 0.2s forwards;
  }

  .monogram {
    font-family: var(--serif-display);
    font-size: clamp(140px, 28vw, 260px);
    line-height: 0.85;
    color: var(--ink);
    letter-spacing: -0.02em;
    opacity: 0;
    animation: fadeUp 1.6s ease-out 0.5s forwards;
    position: relative;
  }

  .monogram::before,
  .monogram::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 60px;
    height: 1px;
    background: var(--hairline-strong);
  }
  .monogram::before { left: -90px; }
  .monogram::after { right: -90px; }

  @media (max-width: 720px) {
    .monogram::before, .monogram::after { width: 30px; }
    .monogram::before { left: -45px; }
    .monogram::after { right: -45px; }
  }

  .cover-title {
    font-family: var(--sans);
    font-size: 13px;
    letter-spacing: 0.7em;
    text-transform: uppercase;
    color: var(--ink);
    margin-top: 36px;
    padding-left: 0.7em;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 0.9s forwards;
  }

  .cover-subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 2.4vw, 24px);
    color: var(--ink-soft);
    margin-top: 28px;
    max-width: 540px;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 1.2s forwards;
  }

  .cover-divider {
    width: 1px;
    height: 56px;
    background: var(--hairline-strong);
    margin: 56px auto 0;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 1.5s forwards;
  }

  .cover-dates {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(15px, 1.8vw, 18px);
    color: var(--ink-soft);
    margin-top: 32px;
    letter-spacing: 0.04em;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 1.5s forwards;
  }

  .countdown {
    margin-top: 48px;
    display: flex;
    gap: 24px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 1.8s forwards;
  }
  .countdown-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    min-width: 60px;
  }
  .countdown-num {
    font-family: var(--serif-display);
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1;
    color: var(--ink);
    font-variant-numeric: lining-nums;
  }
  .countdown-label {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .countdown-sep {
    font-family: var(--serif-display);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--mute-2);
    line-height: 1;
    align-self: flex-start;
    margin-top: 4px;
  }

  @media (max-width: 480px) {
    .countdown { gap: 12px; }
    .countdown-cell { min-width: 44px; }
    .countdown-sep { display: none; }
  }

  .seal {
    margin-top: 80px;
    width: 88px;
    height: 88px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-family: var(--serif-display);
    font-size: 28px;
    cursor: pointer;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), background 0.4s;
    position: relative;
    text-decoration: none;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 2.1s forwards;
  }
  .seal::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    opacity: 0.5;
  }
  .seal:hover {
    background: var(--accent);
    color: var(--bg);
    transform: rotate(45deg);
  }
  .seal:hover::before { border-color: var(--bg); }

  .seal-label {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--mute);
    margin-top: 18px;
    opacity: 0;
    animation: fadeUp 1.4s ease-out 2.3s forwards;
  }

  /* ─────────────  SECTIONS  ───────────── */
  section.chapter {
    padding: 140px 40px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  @media (max-width: 720px) {
    section.chapter { padding: 80px 24px; }
  }

  .chapter-head {
    text-align: center;
    margin-bottom: 80px;
  }
  .chapter-num {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--mute);
    margin-bottom: 20px;
    padding-left: 0.5em;
  }
  .chapter-title {
    font-family: var(--serif-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .chapter-rule {
    width: 40px;
    height: 1px;
    background: var(--accent);
    margin: 28px auto 0;
  }

  /* ─────────────  PREFACE  ───────────── */
  .preface {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }
  .preface p {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.65;
    color: var(--ink-soft);
    font-weight: 300;
  }
  .preface p + p { margin-top: 24px; }
  .preface .ornament {
    margin-top: 48px;
    font-family: var(--serif-display);
    color: var(--mute-2);
    font-size: 24px;
    letter-spacing: 0.6em;
    padding-left: 0.6em;
  }

  /* ─────────────  MAP  ───────────── */
  .map-wrap {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: 48px 32px 32px;
    position: relative;
  }
  .map-wrap::before, .map-wrap::after,
  .map-wrap > .corner-a, .map-wrap > .corner-b {
    content: '';
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1px solid var(--accent);
  }
  .map-wrap::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .map-wrap::after { top: -1px; right: -1px; border-left: 0; border-bottom: 0; }
  .map-wrap > .corner-a { bottom: -1px; left: -1px; border-right: 0; border-top: 0; }
  .map-wrap > .corner-b { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }

  .map-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .map-legend {
    margin-top: 32px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    padding-top: 28px;
    border-top: 1px solid var(--hairline);
  }
  .map-legend-item {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mute);
    line-height: 1.5;
  }
  .map-legend-item strong {
    display: block;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink);
    margin-bottom: 4px;
  }

  /* ─────────────  LODGINGS  ───────────── */
  .lodgings-intro {
    max-width: 620px;
    margin: 0 auto 56px;
    text-align: center;
  }
  .lodgings-intro p {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.65;
    color: var(--ink-soft);
    font-weight: 300;
  }
  .lodgings-intro p + p { margin-top: 18px; }
  .lodgings-intro em {
    font-style: italic;
    color: var(--ink);
  }

  .photo-hero, .photo-banner, .photo-closer {
    border: 1px solid var(--hairline);
    background: var(--surface);
    overflow: hidden;
    position: relative;
  }
  .photo-hero img, .photo-banner img, .photo-closer img {
    display: block;
    width: 100%;
    height: auto;
  }
  .photo-banner { margin-top: 12px; }
  .photo-closer { margin-top: 12px; }

  .photo-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  .photo-row figure {
    margin: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--surface);
    aspect-ratio: 3 / 2;
  }
  .photo-row figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .photo-row figure:hover img,
  .photo-hero:hover img,
  .photo-banner:hover img,
  .photo-closer:hover img {
    transform: scale(1.03);
  }
  .photo-hero img, .photo-banner img, .photo-closer img {
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .photo-caption {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--mute);
    text-align: center;
    margin-top: 24px;
    padding-bottom: 8px;
  }
  .photo-section-divider {
    width: 40px;
    height: 1px;
    background: var(--accent);
    margin: 64px auto 32px;
  }

  @media (max-width: 720px) {
    .photo-row { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .photo-banner, .photo-closer { margin-top: 8px; }
    .photo-row { margin-top: 8px; }
  }

  /* ─────────────  DAY CARDS  ───────────── */
  .days {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .day {
    border-top: 1px solid var(--hairline-strong);
    transition: background 0.4s ease;
  }
  .day:last-child { border-bottom: 1px solid var(--hairline-strong); }
  .day.open { background: var(--surface); }

  .day-header {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 32px;
    align-items: center;
    padding: 36px 24px;
    cursor: pointer;
    width: 100%;
    background: transparent;
    border: 0;
    text-align: left;
    font-family: inherit;
    color: inherit;
    transition: padding 0.4s ease;
  }
  .day.open .day-header { padding-bottom: 24px; }

  .day-num {
    font-family: var(--serif-display);
    font-size: 44px;
    line-height: 1;
    color: var(--accent);
    text-align: center;
    transition: color 0.4s;
  }

  .day-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .day-eyebrow {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .day-title {
    font-family: var(--serif-display);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--ink);
    line-height: 1.05;
  }
  .day-where {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-soft);
    margin-top: 4px;
  }

  .day-toggle {
    width: 36px;
    height: 36px;
    border: 1px solid var(--hairline-strong);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s;
    flex-shrink: 0;
  }
  .day-toggle::before,
  .day-toggle::after {
    content: '';
    background: var(--ink);
    transition: transform 0.4s;
  }
  .day-toggle::before { width: 12px; height: 1px; }
  .day-toggle::after { width: 1px; height: 12px; position: absolute; }
  .day.open .day-toggle { transform: rotate(45deg); border-color: var(--accent); }

  .day-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .day-body-inner {
    padding: 16px 24px 56px;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
  }

  .day-body-inner > .gutter { /* spacer for alignment */ }

  .day-content {
    max-width: 640px;
  }

  .block + .block { margin-top: 36px; }
  .block-label {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--hairline);
  }
  .block-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .block-list li {
    font-family: var(--serif);
    font-size: clamp(17px, 1.7vw, 19px);
    line-height: 1.55;
    color: var(--ink);
    font-weight: 400;
    padding-left: 20px;
    position: relative;
  }
  .block-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--accent);
    font-size: 22px;
    line-height: 1;
    top: 0;
  }
  .block-list em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-soft);
    font-weight: 400;
  }
  .block-list .raw {
    font-style: italic;
    color: var(--accent-deep);
    font-weight: 500;
  }

  .block-time {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--mute);
    margin-left: 8px;
    text-transform: uppercase;
  }

  .day-footer {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .day-footer .item {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mute);
    line-height: 1.6;
  }
  .day-footer .item strong {
    display: block;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink);
    margin-top: 6px;
  }

  @media (max-width: 720px) {
    .day-header {
      grid-template-columns: 56px 1fr auto;
      gap: 16px;
      padding: 28px 0;
    }
    .day-num { font-size: 32px; }
    .day-body-inner {
      grid-template-columns: 1fr;
      padding: 0 0 40px;
    }
    .day-body-inner > .gutter { display: none; }
    .day-footer { grid-template-columns: 1fr; gap: 18px; }
  }

  /* ─────────────  HOUSE RULES  ───────────── */
  .rules {
    background: var(--bg-deep);
    padding: 100px 40px;
    margin-top: 60px;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .rules-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .rules-list {
    list-style: none;
    counter-reset: rule;
  }
  .rules-list li {
    counter-increment: rule;
    padding: 28px 0;
    border-bottom: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .rules-list li:last-child { border-bottom: 0; }
  .rules-list li::before {
    content: counter(rule, upper-roman) '.';
    font-family: var(--serif-display);
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
  }
  .rules-list li p {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.6;
    color: var(--ink);
    font-weight: 400;
  }
  .rules-list li em {
    font-style: italic;
    color: var(--ink-soft);
  }

  @media (max-width: 720px) {
    .rules { padding: 60px 24px; }
    .rules-list li { grid-template-columns: 40px 1fr; gap: 16px; padding: 22px 0; }
    .rules-list li::before { font-size: 22px; }
  }

  /* ─────────────  COLOPHON  ───────────── */
  .colophon {
    padding: 80px 40px 60px;
    text-align: center;
  }
  .colophon-mark {
    font-family: var(--serif-display);
    font-size: 48px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 24px;
  }
  .colophon p {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--mute);
    line-height: 2;
  }
  .colophon .epigraph {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-soft);
    letter-spacing: 0;
    text-transform: none;
    margin: 32px auto 16px;
    max-width: 480px;
